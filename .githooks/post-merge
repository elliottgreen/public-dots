#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
config_dotfiles_dir="$repo_root/dotfiles"
home_dotfiles_dir="$repo_root/dotfiles-homedir"

cd "$repo_root"

changed_files="$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD)"

config_changed=false
home_changed=false

if printf '%s\n' "$changed_files" | grep -q '^dotfiles/'; then
  config_changed=true
fi

if printf '%s\n' "$changed_files" | grep -q '^dotfiles-homedir/'; then
  home_changed=true
fi

if [ "$config_changed" = false ] && [ "$home_changed" = false ]; then
  exit 0
fi

if ! command -v stow >/dev/null 2>&1; then
  echo "[dotfiles] ERROR: GNU Stow is not installed or not in PATH." >&2
  exit 1
fi

if [ "$config_changed" = true ]; then
  if [ ! -d "$config_dotfiles_dir" ]; then
    echo "[dotfiles] ERROR: dotfiles directory not found: $config_dotfiles_dir" >&2
    exit 1
  fi

  mkdir -p "$HOME/.config"

  echo "[dotfiles] Re-applying ~/.config dotfiles..."
  stow \
    --target="$HOME/.config" \
    --restow \
    dotfiles
fi

if [ "$home_changed" = true ]; then
  if [ ! -d "$home_dotfiles_dir" ]; then
    echo "[dotfiles] ERROR: dotfiles-homedir directory not found: $home_dotfiles_dir" >&2
    exit 1
  fi

  echo "[dotfiles] Re-applying home-directory dotfiles..."
  stow \
    --target="$HOME" \
    --dotfiles \
    --restow \
    dotfiles-homedir
fi

echo "[dotfiles] Done."
