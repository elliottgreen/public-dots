#!/bin/zsh 
# commands

# Start recording with Asciinema and pass a title
arec() {
  local title="${1:-$(date)}"
  asciinema rec -i 2 -t "$title" "$HOME/Videos/Shell-Caps/asciinema/${title}.cast"
}

aplay() {
  asciinema play "$HOME/Videos/Shell-Caps/asciinema/$1.cast"
}

